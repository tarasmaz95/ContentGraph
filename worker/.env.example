CONTENTGRAPH_API_URL=https://tm1.website/api/v1
WORKER_TOKEN=paste-from-dashboard-register
EXTENSION_PATH=../extension
# Use Playwright Chromium for reliable MV3 extension injection, especially on macOS.
BROWSER_CHANNEL=chromium
CHROME_USER_DATA_DIR=~/.contentgraph-worker/chromium-profile
WORKER_STATE_DIR=~/.contentgraph-worker/state
JOB_DELAY_MIN_MS=3000
JOB_DELAY_MAX_MS=8000
HEARTBEAT_INTERVAL_MS=12000
PHASE_TIMEOUT_MS=120000
NAVIGATION_TIMEOUT_MS=90000
STUCK_PAGE_MS=180000
SCREENSHOT_DIR=./screenshots
RESTART_BROWSER_EVERY_JOBS=20
PHASE_RETRIES=2
REQUIRED_EXTENSION_VERSION=0.2.5

# Daily safety limits (0 = unlimited)
BROWSER_INGESTION_MAX_JOBS_PER_DAY=200
BROWSER_INGESTION_MAX_CONSECUTIVE_FAILURES=5
BROWSER_INGESTION_COOLDOWN_MINUTES=30
