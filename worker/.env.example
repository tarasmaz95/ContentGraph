CONTENTGRAPH_API_URL=https://tm1.website/api/v1
WORKER_TOKEN=paste-from-dashboard-register
EXTENSION_PATH=../extension
# Worker jobs: Playwright Chromium (reliable MV3 extension on macOS).
BROWSER_CHANNEL=chromium
# Google sign-in (`npm run browser`): real Chrome — Chromium gets "browser may not be secure".
LOGIN_BROWSER_CHANNEL=chrome
# Optional: export cookies from normal Chrome (Cookie-Editor) → this file if sign-in still fails
# COOKIES_FILE=~/.contentgraph-worker/state/cookies.json
CHROME_USER_DATA_DIR=~/.contentgraph-worker/chromium-profile
WORKER_STATE_DIR=~/.contentgraph-worker/state
JOB_DELAY_MIN_MS=3000
JOB_DELAY_MAX_MS=8000
HEARTBEAT_INTERVAL_MS=12000
PHASE_TIMEOUT_MS=120000
NAVIGATION_TIMEOUT_MS=90000
STUCK_PAGE_MS=180000
SCREENSHOT_DIR=./screenshots
RESTART_BROWSER_EVERY_JOBS=20
PHASE_RETRIES=2
REQUIRED_EXTENSION_VERSION=0.2.8

# Daily jobs cap per UTC day — 0 = unlimited (no daily limit)
BROWSER_INGESTION_MAX_JOBS_PER_DAY=0
# Only infrastructure failures count (timeout, browser_crash, youtube_blocked, extension_error,
# unknown). "Soft" outcomes — no captions / comments disabled / empty — never bump the counter.
BROWSER_INGESTION_MAX_CONSECUTIVE_FAILURES=20
BROWSER_INGESTION_COOLDOWN_MINUTES=30
