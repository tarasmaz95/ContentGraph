DATABASE_URL=postgresql+asyncpg://contentgraph:contentgraph@postgres:5432/contentgraph
CORS_ORIGINS=http://localhost:3000

GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
GOOGLE_SERVICE_ACCOUNT_FILE=credentials/service_account.json
GOOGLE_SHEETS_RANGE=Sheet1!A:F
SHEETS_WRITEBACK_ENABLED=true
TM1_PUBLIC_URL=https://tm1.website

# Optional — require X-Extension-Key on transcript/comments ingest when set
EXTENSION_API_KEY=

OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-5.4
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# YouTube Data API v3 — top comments ingestion (enable API in Google Cloud)
YOUTUBE_API_KEY=
# Optional proxy for native transcript batch fetch (required on many cloud VPS IPs)
TRANSCRIPT_HTTP_PROXY=

STATS_SCHEDULER_ENABLED=true
STATS_SNAPSHOT_HOUR_UTC=3
STATS_SNAPSHOT_MINUTE_UTC=15
STATS_RUN_ON_STARTUP=false
COMMENTS_MAX_PER_VIDEO=25
COMMENTS_ENRICH_LIMIT=15
